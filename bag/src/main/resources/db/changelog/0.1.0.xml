      <column name="LOG_USU_ALT" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_INC" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_CANCEL" type="INT">
        <constraints nullable="true"/>
      </column>
    </createTable>

    <createTable tableName="Imoveis">
      <column name="IMO_ID" type="INT" autoIncrement="true">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="IMO_PES_ID" type="INT">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_IPTU" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_LOGRADOURO" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_NUM" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_COMPLEMENTO" type="VARCHAR(255)">
        <constraints nullable="true"/>
      </column>
      <column name="IMO_CEP" type="CHAR(8)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_BAIRRO" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_CIDADE" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_UF" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_INCLUSAO" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_ALTERACAO" type="timestamp">
        <constraints nullable="true"/>
      </column>
      <column name="IMO_CANCEL" type="BOOLEAN">
        <constraints nullable="false"/>
      </column>
      <column name="LOG_USU_ALT" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_INC" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_CANCEL" type="INT">
        <constraints nullable="true"/>
      </column>
    </createTable>
    
    <addForeignKeyConstraint baseTableName="Alocacao" baseColumnNames="LOC_PES_ID"
      constraintName="FK_PES_ID_IN_LOC_PES_ID"
      referencedTableName="Pessoa" referencedColumnNames="PES_ID"/>
    <addForeignKeyConstraint baseTableName="Alocacao" baseColumnNames="LOC_BAG_ID"
      constraintName="FK_BAG_ID_IN_LOC_BAG_ID"
      referencedTableName="Bag" referencedColumnNames="BAG_ID"/>
    <addForeignKeyConstraint baseTableName="Imoveis" baseColumnNames="IMO_PES_ID"
      constraintName="FK_PES_ID_IN_IMO_PES_ID"
      referencedTableName="Pessoa" referencedColumnNames="PES_ID"/>
  </changeSet>
</databaseChangeLog>