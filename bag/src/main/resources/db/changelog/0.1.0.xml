<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
  xmlns:pro="http://www.liquibase.org/xml/ns/pro"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
        http://www.liquibase.org/xml/ns/dbchangelog-ext
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
        http://www.liquibase.org/xml/ns/pro
        http://www.liquibase.org/xml/ns/pro/liquibase-pro-latest.xsd">

  <changeSet id="0.1.0" author="Arthur">
    <tagDatabase tag="0.1.0"/>
  </changeSet>

  <changeSet id="0.1.1" author="Arthur">
    <createTable tableName="pessoa">
      <column name="PES_ID" type="INT" autoIncrement="true">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="PES_NOME" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="PES_CPF" type="CHAR(14)">
        <constraints nullable="false"/>
      </column>
      <column name="PES_FONE" type="VARCHAR(30)">
        <constraints nullable="true"/>
      </column>
      <column name="PES_CELULAR" type="CHAR(11)">
        <constraints nullable="true"/>
      </column>
      <column name="PES_INCLUSAO" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="PES_ALTERACAO" type="TIMESTAMP">
        <constraints nullable="true"/>
      </column>
      <column name="PES_CANCEL" type="BOOLEAN">
        <constraints nullable="false"/>
      </column>
      <column name="LOG_USU_ALT" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_INC" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_CANCEL" type="INT">
        <constraints nullable="true"/>
      </column>
    </createTable>

    <createTable tableName="usuario">
      <column name="USU_ID" type="INT" autoIncrement="true">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="USU_SENHA" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="USU_NOME" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="USU_EMAIL" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="USU_DATA_INCLUSAO" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="USU_DATA_ALTERACAO" type="timestamp">
        <constraints nullable="true"/>
      </column>
      <column name="USU_CANCEL" type="BOOLEAN">
        <constraints nullable="false"/>
      </column>
      <column name="LOG_USU_ALT" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_INC" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_CANCEL" type="INT">
        <constraints nullable="true"/>
      </column>
    </createTable>

    <createTable tableName="bag">
      <column name="BAG_ID" type="INT" autoIncrement="true">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="BAG_DISPO" type="BOOLEAN">
        <constraints nullable="false"/>
      </column>
      <column name="BAG_NUM" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="BAG_OBSERVACAO" type="VARCHAR(255)">
        <constraints nullable="true"/>
      </column>
      <column name="BAG_INCLUSAO" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="BAG_ALTERACAO" type="timestamp">
        <constraints nullable="true"/>
      </column>
      <column name="BAG_CANCEL" type="BOOLEAN">
        <constraints nullable="false"/>
      </column>
      <column name="LOG_USU_ALT" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_INC" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_CANCEL" type="INT">
        <constraints nullable="true"/>
      </column>
    </createTable>

    <createTable tableName="alocacao">
      <column name="LOC_ID" type="INT" autoIncrement="true">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="LOC_PES_ID" type="INT">
        <constraints nullable="false"/>
      </column>
      <column name="LOC_BAG_ID" type="INT">
        <constraints nullable="false"/>
      </column>
      <column name="LOC_DATA_DEVOLUÇÃO" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="LOC_DATA_ENTREGA" type="timestamp">
        <constraints nullable="true"/>
      </column>
      <column name="LOC_STATUS" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="LOC_INCLUSAO" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="LOC_ALTERACAO" type="timestamp">
        <constraints nullable="true"/>
      </column>
      <column name="LOC_CANCEL" type="BOOLEAN">
        <constraints nullable="false"/>
      </column>
      <column name="LOG_USU_ALT" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_INC" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_CANCEL" type="INT">
        <constraints nullable="true"/>
      </column>
    </createTable>

    <createTable tableName="imoveis">
      <column name="IMO_ID" type="INT" autoIncrement="true">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="IMO_PES_ID" type="INT">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_IPTU" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_LOGRADOURO" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_NUM" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_COMPLEMENTO" type="VARCHAR(255)">
        <constraints nullable="true"/>
      </column>
      <column name="IMO_CEP" type="CHAR(8)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_BAIRRO" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_CIDADE" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_UF" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_INCLUSAO" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="IMO_ALTERACAO" type="timestamp">
        <constraints nullable="true"/>
      </column>
      <column name="IMO_CANCEL" type="BOOLEAN">
        <constraints nullable="false"/>
      </column>
      <column name="LOG_USU_ALT" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_INC" type="INT">
        <constraints nullable="true"/>
      </column>
      <column name="LOG_USU_CANCEL" type="INT">
        <constraints nullable="true"/>
      </column>
    </createTable>

    <addForeignKeyConstraint baseTableName="alocacao" baseColumnNames="LOC_PES_ID"
      constraintName="FK_PES_ID_IN_LOC_PES_ID"
      referencedTableName="pessoa" referencedColumnNames="PES_ID"/>
    <addForeignKeyConstraint baseTableName="alocacao" baseColumnNames="LOC_BAG_ID"
      constraintName="FK_BAG_ID_IN_LOC_BAG_ID"
      referencedTableName="bag" referencedColumnNames="BAG_ID"/>
    <addForeignKeyConstraint baseTableName="imoveis" baseColumnNames="IMO_PES_ID"
      constraintName="FK_PES_ID_IN_IMO_PES_ID"
      referencedTableName="pessoa" referencedColumnNames="PES_ID"/>
  </changeSet>

  <changeSet id="0.1.2" author="Arthur">
    <addColumn tableName="usuario">
      <column name="USU_ADMIN" type="BOOLEAN" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
    </addColumn>
  </changeSet>

  <changeSet id="0.1.3" author="Arthur">
    <createTable tableName="refresh_token">
      <column name="TOK_ID" type="UUID">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="TOK_TOKEN_JWT" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="TOK_TEMPO_EXPIRACAO" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="TOK_USUARIO_ID" type="INT">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint baseTableName="refresh_token" baseColumnNames="TOK_USUARIO_ID"
      constraintName="FK_USU_ID_IN_TOK_USUARIO_ID"
      referencedTableName="usuario" referencedColumnNames="USU_ID"/>
  </changeSet>
</databaseChangeLog>